{
  "schemaVersion": 1,
  "kind": "sdkwork.app.config",
  "app": {
    "name": "sdkwork-xiangqi",
    "displayName": "SDKWork Xiangqi",
    "version": "0.1.0",
    "description": "SDKWork Chinese chess (xiangqi) platform for matches, rooms, and leaderboards",
    "owner": "sdkwork-xiangqi",
    "domain": "game",
    "capability": "match",
    "key": "sdkwork-xiangqi",
    "appType": "APP_HTML",
    "officialWebsiteUrl": "https://sdkwork.com/apps/sdkwork-xiangqi"
  },
  "runtime": {
    "apiBaseUrl": "http://localhost:8098",
    "appApiPrefix": "/app/v3/api",
    "backendApiPrefix": "/backend/v3/api",
    "supportedDeploymentProfiles": [
      "standalone",
      "cloud"
    ],
    "defaultDeploymentProfile": "standalone"
  },
  "sdk": {
    "appApiAuthority": "sdkwork-xiangqi-app-api",
    "backendApiAuthority": "sdkwork-xiangqi-backend-api",
    "appSdkFamily": "sdkwork-xiangqi-app-sdk",
    "backendSdkFamily": "sdkwork-xiangqi-backend-sdk"
  },
  "sdkDependencies": [],
  "dependencyApiExports": [],
  "dependencyApiSurfaces": [],
  "features": {
    "match": true,
    "rooms": true,
    "leaderboards": true
  },
  "backend": {
    "profileKey": "backend-root-admin",
    "accessTokenPermissionScope": [
      "iam.users.read",
      "iam.organizations.read",
      "iam.roles.read",
      "iam.permissions.read"
    ],
    "tenantId": "100001",
    "organizationId": "0"
  },
  "environments": {}
}
