{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@sdkwork/utils": [
        "../sdkwork-utils/packages/sdkwork-utils-typescript/src/index.ts"
      ],
      "@sdkwork/xiangqi-contracts": [
        "apps/sdkwork-xiangqi-common/packages/sdkwork-xiangqi-contracts/src/index.ts"
      ]
    }
  },
  "include": [
    "apps/sdkwork-xiangqi-common/packages/*/src/**/*.ts",
    "apps/sdkwork-xiangqi-pc/packages/sdkwork-xiangqi-pc-core/src/sdk/**/*.ts",
    "apps/sdkwork-xiangqi-pc/packages/sdkwork-xiangqi-pc-core/src/composition/**/*.ts",
    "sdks/*/*-typescript/src/**/*.ts"
  ],
  "exclude": [
    "**/node_modules/**",
    "**/generated/**"
  ]
}
