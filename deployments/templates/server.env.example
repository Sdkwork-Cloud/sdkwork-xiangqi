# Copy to host-local override (for example .env.local) ŌĆ?do not commit secrets.

SDKWORK_DEPLOYMENT_PROFILE=cloud
SDKWORK_SERVICE_LAYOUT=container
SDKWORK_RUNTIME_TARGET=container
sdkwork_xiangqi_APP_ROOT=/app/sdkwork-xiangqi

XIANGQI_REPOSITORY_MODE=sqlx
XIANGQI_DATABASE_URL=postgres://sdkwork:sdkwork@postgres:5432/sdkwork_xiangqi
XIANGQI_DATABASE_AUTO_MIGRATE=true

RUST_LOG=info,sdkwork_xiangqi_api_server=debug
XIANGQI_API_BIND=0.0.0.0:8098
