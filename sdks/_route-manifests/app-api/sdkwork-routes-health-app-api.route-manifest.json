      "handler": {
        "module": "crate",
        "name": "xiangqi_ready_check"
      },
      "schemas": {
        "request": null,
        "response": "XiangqiHealthResponse",
        "problem": "ProblemDetail"
      },
      "ownership": {
        "owner": "sdkwork-xiangqi",
        "apiAuthority": "sdkwork-xiangqi-app-api"
      },
      "source": {
        "file": "apis/app-api/game/xiangqi-app-api.openapi.json"
