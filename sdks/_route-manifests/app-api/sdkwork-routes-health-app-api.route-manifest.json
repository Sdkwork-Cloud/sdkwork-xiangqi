{
  "schemaVersion": 1,
  "kind": "sdkwork.route.manifest",
  "packageName": "sdkwork-routes-health-app-api",
  "surface": "app-api",
  "owner": "sdkwork-xiangqi",
  "domain": "game",
  "capability": "health",
