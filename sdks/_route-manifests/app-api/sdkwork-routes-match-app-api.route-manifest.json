{
  "schemaVersion": 1,
  "kind": "sdkwork.route.manifest",
  "packageName": "sdkwork-routes-match-app-api",
  "surface": "app-api",
  "owner": "sdkwork-xiangqi",
  "domain": "game",
  "capability": "match",
  "apiAuthority": "sdkwork-xiangqi-app-api",
